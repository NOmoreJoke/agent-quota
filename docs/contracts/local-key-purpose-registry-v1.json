{
  "$schema": "https://agent-quota.local/contracts/schemas/local-key-purpose-registry-v1.schema.json",
  "$id": "https://agent-quota.local/contracts/local-key-purpose-registry-v1.json",
  "schema": "aq-local-key-purpose-registry-v1",
  "artifact_id": "local-key-purpose-registry-v1",
  "root_key_bytes": 32,
  "derived_key_bytes": 32,
  "kdf": {
    "algorithm": "HKDF-SHA-256",
    "extract_salt_recipe": "SHA256(ASCII('agent-quota:local-purpose-extract:v1\\x00') || aq-jcs-nfc-v1({installation_id,purpose,generation}))",
    "expand_info_recipe": "ASCII('agent-quota:local-purpose-expand:v1\\x00') || u16be(len(UTF8-NFC(purpose))) || UTF8-NFC(purpose) || u64be(generation)",
    "generation_range": [1, 9223372036854775807],
    "integer_encoding": "unsigned-big-endian",
    "string_encoding": "UTF-8-NFC",
    "output_length_bytes": 32
  },
  "purposes": [
    {
      "purpose": "access-identity-v1",
      "rotation": "replace_generation",
      "verify_only_allowed": false
    },
    {
      "purpose": "action-signing-v1",
      "rotation": "verify_only",
      "verify_only_allowed": true
    },
    {
      "purpose": "cache-identity-v1",
      "rotation": "replace_generation",
      "verify_only_allowed": false
    },
    {
      "purpose": "idempotency-binding-v1",
      "rotation": "verify_only",
      "verify_only_allowed": true
    },
    {
      "purpose": "pseudonym-v1",
      "rotation": "verify_only",
      "verify_only_allowed": true
    },
    {
      "purpose": "query-generation-v1",
      "rotation": "replace_generation",
      "verify_only_allowed": false
    },
    {
      "purpose": "rate-ledger-v1",
      "rotation": "verify_only",
      "verify_only_allowed": true
    },
    {
      "purpose": "rate-limit-cohort-v1",
      "rotation": "verify_only",
      "verify_only_allowed": true
    }
  ],
  "consumers": [
    {"consumer_id":"access-generation-digest-v1","purpose":"access-identity-v1","new_value_policy":"active_generation_only","verification_lookup_policy":"active_only"},
    {"consumer_id":"action-sign-and-verify-v1","purpose":"action-signing-v1","new_value_policy":"active_generation_only","verification_lookup_policy":"active_then_verify_only_descending"},
    {"consumer_id":"cache-identity-prf-v1","purpose":"cache-identity-v1","new_value_policy":"active_generation_only","verification_lookup_policy":"active_only"},
    {"consumer_id":"idempotency-binding-digest-v1","purpose":"idempotency-binding-v1","new_value_policy":"active_generation_only","verification_lookup_policy":"active_then_verify_only_descending"},
    {"consumer_id":"pseudonymous-reference-v1","purpose":"pseudonym-v1","new_value_policy":"active_generation_only","verification_lookup_policy":"active_then_verify_only_descending"},
    {"consumer_id":"query-contract-generation-v1","purpose":"query-generation-v1","new_value_policy":"active_generation_only","verification_lookup_policy":"active_only"},
    {"consumer_id":"rate-ledger-record-digest-v1","purpose":"rate-ledger-v1","new_value_policy":"active_generation_only","verification_lookup_policy":"active_then_verify_only_descending"},
    {"consumer_id":"rate-limit-cohort-prf-v1","purpose":"rate-limit-cohort-v1","new_value_policy":"active_generation_only","verification_lookup_policy":"active_then_verify_only_descending"}
  ],
  "key_entry_semantics": {
    "key_id_recipe": "'aqk_' || lowercase_hex(SHA256(ASCII('agent-quota:local-key-id:v1\\x00') || u16be(len(UTF8-NFC(installation_id))) || UTF8-NFC(installation_id) || u16be(len(UTF8-NFC(purpose))) || UTF8-NFC(purpose) || u64be(generation) || public_salt_16 || key_material_32))",
    "public_salt": {
      "bytes": 16,
      "generation": "CSPRNG-per-key-entry",
      "secret": false,
      "role": "key-id-domain-separation-only",
      "kdf_input": false
    },
    "load_validation": [
      "decode-fixed-length-fields",
      "recompute-key-id",
      "constant-time-key-id-compare",
      "sort-by-purpose-then-generation",
      "reject-duplicate-purpose-generation",
      "reject-multiple-active-per-purpose",
      "reject-missing-active-for-registered-purpose",
      "reject-unregistered-purpose",
      "reject-verify-only-for-purpose-that-forbids-it"
    ],
    "entry_order": "UTF8-NFC(purpose)-bytes-ascending-then-generation-ascending",
    "unique_tuple": ["purpose", "generation"],
    "active_cardinality_per_purpose": 1,
    "generation_transition": {
      "replace_generation": "remove-old-active-and-add-new-active-at-old-generation-plus-one-atomically",
      "verify_only": "change-old-active-to-verify_only-and-add-new-active-at-old-generation-plus-one-atomically",
      "generation_reuse": "reject",
      "generation_skip": "reject"
    }
  },
  "verification_lookup_policies": [
    {"policy_id":"active_only","generation_order":"active_generation_only","max_generations":1,"deduplicate_by":"final_record_digest","retire_when":"replacement_committed_and_no_persistent_reference"},
    {"policy_id":"active_then_verify_only_descending","generation_order":"active_first_then_verify_only_generation_descending","max_generations":4,"deduplicate_by":"final_record_digest","retire_when":"all_named_surface_retention_windows_expired_and_reference_count_zero"}
  ],
  "persistent_surfaces": [
    {"surface_id":"action-consumption-records","consumer_ids":["action-sign-and-verify-v1"],"combination_order":"consumer_order_then_generation_order","max_candidate_combinations":4,"retirement_condition":"RET-IDEM-FEISHU-CARD-and-RET-KEY-VERIFY-expired-and-reference-count-zero"},
    {"surface_id":"idempotency-records","consumer_ids":["idempotency-binding-digest-v1"],"combination_order":"consumer_order_then_generation_order","max_candidate_combinations":4,"retirement_condition":"channel-RET-IDEM-window-expired-and-reference-count-zero"},
    {"surface_id":"pseudonymous-associations","consumer_ids":["pseudonymous-reference-v1"],"combination_order":"consumer_order_then_generation_order","max_candidate_combinations":4,"retirement_condition":"owning-RET-window-expired-and-reference-count-zero"},
    {"surface_id":"rate-ledger-records","consumer_ids":["rate-ledger-record-digest-v1","rate-limit-cohort-prf-v1"],"combination_order":"consumer_id_utf8_ascending_cartesian_then_generation_descending","max_candidate_combinations":16,"retirement_condition":"RET-RATE-LEDGER-expired-and-reference-count-zero"}
  ],
