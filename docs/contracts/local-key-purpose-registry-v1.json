  "closure_rules": {
    "purpose_order": "UTF-8 byte ascending",
    "purpose_unique": true,
    "unknown_purpose": "reject",
    "duplicate_purpose": "reject",
    "same_derived_key_for_distinct_purpose_generation": "reject",
    "consumer_may_use_only_named_purpose": true,
    "consumer_id_unique": true,
    "purpose_to_consumer_nonempty": true,
    "consumer_to_purpose_exactly_one": true,
    "consumer_purpose_reference_closure": "reject",
    "persistent_surface_consumer_reference_closure": "reject",
    "every_verify_only_consumer_has_bounded_lookup": true,
    "new_values_never_use_verify_only_generation": true,
    "candidate_combination_overflow": "reject",
    "candidate_deduplication_before_lookup": true,
    "root_key_direct_use": "reject",
    "key_id_recompute_on_load": true,
    "public_salt_used_as_secret_or_kdf_input": "reject",
    "generation_transition_mismatch": "reject",
    "golden_payload_envelope_required": true,
    "payload_purpose_set_equals_registry": true,
    "exactly_one_active_per_registered_purpose": true
  }
