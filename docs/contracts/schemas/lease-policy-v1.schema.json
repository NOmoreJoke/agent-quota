{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-quota.local/contracts/schemas/lease-policy-v1.schema.json",
  "title": "Agent Quota lease policy v1",
  "type": "object",
  "required": [
    "$schema",
    "$id",
    "schema",
    "artifact_id",
    "boundary_formula_id",
    "renew_formula_id",
    "takeover_formula_id",
    "provider_io_deadline_formula_id",
    "clock_domains",
    "conversion_rule",
    "operators",
    "operand_definitions",
    "formula_definitions",
    "policies",
    "closure_rules"
  ],
  "properties": {
    "$schema": {
      "const": "https://agent-quota.local/contracts/schemas/lease-policy-v1.schema.json"
    },
    "$id": {
      "const": "https://agent-quota.local/contracts/lease-policy-v1.json"
    },
    "schema": {
      "const": "aq-lease-policy-v1"
    },
    "artifact_id": {
      "const": "lease-policy-v1"
    },
    "boundary_formula_id": {
      "$ref": "#/$defs/id"
    },
    "renew_formula_id": {
      "$ref": "#/$defs/id"
    },
    "takeover_formula_id": {
      "$ref": "#/$defs/id"
    },
    "provider_io_deadline_formula_id": {
      "$ref": "#/$defs/id"
    },
    "clock_domains": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/clock"
      },
      "minItems": 2,
      "maxItems": 2
    },
    "conversion_rule": {
      "$ref": "#/$defs/conversion"
    },
    "operators": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/operator"
      },
      "minItems": 1,
      "maxItems": 32
    },
    "operand_definitions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/operand"
      },
      "minItems": 1,
      "maxItems": 64
    },
    "formula_definitions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/formula"
      },
      "minItems": 1,
      "maxItems": 64
    },
    "policies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/policy"
      },
      "minItems": 1,
      "maxItems": 64
    },
    "closure_rules": {
      "$ref": "#/$defs/closure"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._-]{0,127}$",
      "maxLength": 128
    },
    "intMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9223372036854775807
    },
    "clock": {
      "type": "object",
      "required": [
        "clock_id",
        "unit",
        "source",
        "rollback_policy"
      ],
      "properties": {
        "clock_id": {
          "enum": [
            "db_utc_ms",
            "process_monotonic_ns"
          ]
        },
        "unit": {
          "enum": [
            "milliseconds",
            "nanoseconds"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "rollback_policy": {
          "enum": [
            "do-not-expire-early-until-next-successful-transaction-sample",
            "fatal-process-invariant"
          ]
        }
      },
      "additionalProperties": false
    },
    "conversion": {
      "type": "object",
      "required": [
        "conversion_id",
        "sample_order",
        "input_type",
        "input_unit",
        "input_clock_domain",
        "result_type",
        "result_unit",
        "result_clock_domain",
        "expression",
        "overflow_verdict"
      ],
      "properties": {
        "conversion_id": {
          "const": "monotonic-remaining-to-db-utc-v1"
        },
        "sample_order": {
          "const": [
            "monotonic_before_ns",
            "db_utc_ms",
            "monotonic_after_ns"
          ]
        },
        "input_type": {
          "const": "int64_ns"
        },
        "input_unit": {
          "const": "nanoseconds"
        },
        "input_clock_domain": {
          "const": "process_monotonic_ns"
        },
        "result_type": {
          "const": "int64_ms"
        },
        "result_unit": {
          "const": "milliseconds"
        },
        "result_clock_domain": {
          "const": "db_utc_ms"
        },
        "expression": {
          "$ref": "#/$defs/ast"
        },
        "overflow_verdict": {
          "const": "reject_without_state_change"
        }
      },
      "additionalProperties": false
    },
    "operator": {
      "type": "object",
      "required": [
        "op",
        "input_type",
        "output_type",
        "min_args",
        "max_args",
        "overflow"
      ],
      "properties": {
        "op": {
          "enum": [
            "and",
            "checked_add",
            "checked_increment_u63",
            "floor_div_ns_to_ms",
            "greater_or_equal",
            "less_than",
            "min",
            "min_int64_ns",
            "subtract_clamped_zero_int64_ns",
            "subtract_nonnegative"
          ]
        },
        "input_type": {
          "enum": [
            "boolean[]",
            "int64_ms[]",
            "int64_ms_pair",
            "int64_ns",
            "int64_ns[]",
            "int64_ns_pair",
            "same_scalar_pair",
            "uint63"
          ]
        },
        "output_type": {
          "enum": [
            "boolean",
            "int64_ms",
            "int64_ns",
            "uint63"
          ]
        },
        "min_args": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        "max_args": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        "overflow": {
          "enum": [
            "not-applicable",
            "reject_without_state_change"
          ]
        }
      },
      "additionalProperties": false
    },
    "operand": {
      "type": "object",
      "required": [
        "operand_id",
        "type",
        "clock_id",
        "source"
      ],
      "properties": {
        "operand_id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "enum": [
            "int64_ms",
            "int64_ns",
            "uint63"
          ]
        },
        "clock_id": {
          "oneOf": [
            {
              "enum": [
                "db_utc_ms",
                "process_monotonic_ns"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "constant": {
          "$ref": "#/$defs/typedConstant"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties":{"source":{"const":"typed-constant"}},"required":["source"]},
          "then": {"required":["constant"],"properties":{"clock_id":{"type":"null"}}},
          "else": {"not":{"required":["constant"]}}
        }
      ]
    },
    "typedConstant": {
      "type": "object",
      "required": ["type", "unit", "value"],
      "properties": {
        "type": {"const":"int64_ms"},
        "unit": {"const":"milliseconds"},
        "value": {"$ref":"#/$defs/intMs"}
      },
      "additionalProperties": false
    },
    "typedLiteral": {
      "oneOf": [
        {"type":"object","required":["type","unit","value"],"properties":{"type":{"const":"int64_ms"},"unit":{"const":"milliseconds"},"value":{"$ref":"#/$defs/intMs"}},"additionalProperties":false},
        {"type":"object","required":["type","unit","value"],"properties":{"type":{"const":"int64_ns"},"unit":{"const":"nanoseconds"},"value":{"type":"integer","minimum":0,"maximum":9223372036854775807}},"additionalProperties":false},
        {"type":"object","required":["type","unit","value"],"properties":{"type":{"const":"uint63"},"unit":{"const":"dimensionless"},"value":{"type":"integer","minimum":1,"maximum":9223372036854775807}},"additionalProperties":false},
        {"type":"object","required":["type","unit","value"],"properties":{"type":{"const":"boolean"},"unit":{"const":"boolean"},"value":{"type":"boolean"}},"additionalProperties":false},
        {"type":"object","required":["type","unit","value"],"properties":{"type":{"const":"not_applicable"},"unit":{"const":"none"},"value":{"type":"null"}},"additionalProperties":false}
      ]
    },
    "ast": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "operand"
          ],
          "properties": {
            "operand": {
              "$ref": "#/$defs/id"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "literal"
          ],
          "properties": {
            "literal": {
              "$ref": "#/$defs/typedLiteral"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "formula_ref"
          ],
          "properties": {
            "formula_ref": {
              "$ref": "#/$defs/id"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "convert",
            "deadline"
          ],
          "properties": {
            "convert": {
              "const": "monotonic-remaining-to-db-utc-v1"
            },
            "deadline": {
              "$ref": "#/$defs/ast"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "op",
            "args"
          ],
          "properties": {
            "op": {
              "enum": [
                "and",
                "checked_add",
                "checked_increment_u63",
                "floor_div_ns_to_ms",
                "greater_or_equal",
                "less_than",
                "min",
                "min_int64_ns",
                "subtract_clamped_zero_int64_ns",
                "subtract_nonnegative"
              ]
            },
            "args": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/ast"
              },
              "minItems": 1,
              "maxItems": 8
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "formulaExpression": {
      "oneOf": [
        {
          "$ref": "#/$defs/ast"
        },
        {
          "type": "object",
          "required": [
            "eligible",
            "next_fencing_token",
            "transaction"
          ],
          "properties": {
            "eligible": {
              "$ref": "#/$defs/ast"
            },
            "next_fencing_token": {
              "$ref": "#/$defs/ast"
            },
            "transaction": {
              "const": "BEGIN IMMEDIATE"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "formula": {
      "type": "object",
      "required": [
        "formula_id",
        "result_type",
        "result_unit",
        "result_clock_domain",
        "expression"
      ],
      "properties": {
        "formula_id": {
          "$ref": "#/$defs/id"
        },
        "result_type": {
          "enum": [
            "boolean",
            "int64_ms",
            "int64_ns",
            "not_applicable",
            "takeover_pair"
          ]
        },
        "result_unit": {
          "enum": [
            "boolean",
            "milliseconds",
            "nanoseconds",
            "none",
            "structured"
          ]
        },
        "result_clock_domain": {
          "oneOf": [
            {
              "enum": [
                "db_utc_ms",
                "process_monotonic_ns"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "expression": {
          "$ref": "#/$defs/formulaExpression"
        }
      },
      "additionalProperties": false
    },
    "policy": {
      "type": "object",
      "required": [
        "policy_id",
        "object_class",
        "duration_ms",
        "renew_before_ms",
        "max_lifetime_ms",
        "expiry_formula_id",
        "expiry_formula_expected",
        "parent_deadline_formula_id",
        "parent_deadline_formula_expected",
        "on_expiry"
      ],
      "properties": {
        "policy_id": {
          "$ref": "#/$defs/id"
        },
        "object_class": {
          "$ref": "#/$defs/id"
        },
        "duration_ms": {
          "$ref": "#/$defs/intMs"
        },
        "renew_before_ms": {
          "$ref": "#/$defs/intMs"
        },
        "max_lifetime_ms": {
          "$ref": "#/$defs/intMs"
        },
        "expiry_formula_id": {
          "$ref": "#/$defs/id"
        },
        "expiry_formula_expected": {
          "$ref": "#/$defs/resultSignature"
        },
        "parent_deadline_formula_id": {
          "$ref": "#/$defs/id"
        },
        "parent_deadline_formula_expected": {
          "$ref": "#/$defs/resultSignature"
        },
        "on_expiry": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{0,127}$",
          "maxLength": 128
        }
      },
      "additionalProperties": false
    },
    "resultSignature": {
      "type": "object",
      "required": [
        "value_type",
        "unit",
        "clock_domain"
      ],
      "properties": {
        "value_type": {
          "enum": [
            "boolean",
            "int64_ms",
            "int64_ns",
            "not_applicable",
            "takeover_pair",
            "uint63"
          ]
        },
        "unit": {
          "enum": [
            "boolean",
            "dimensionless",
            "milliseconds",
            "nanoseconds",
            "none",
            "structured"
          ]
        },
        "clock_domain": {
          "oneOf": [
            {
              "enum": [
                "db_utc_ms",
                "process_monotonic_ns"
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "closure": {
      "type": "object",
      "required": [
        "policy_id_unique",
        "object_class_unique",
        "unknown_policy",
        "formula_id_unique",
        "all_formula_references_resolve",
        "unused_formula",
        "all_operand_references_resolve",
        "all_operator_references_resolve",
        "operator_type_mismatch",
        "clock_domain_mismatch",
        "overflow",
        "negative_or_fractional_milliseconds",
        "duration_le_max_lifetime",
        "renew_before_lt_duration",
        "db_clock_backward",
        "monotonic_clock_rollback",
        "conversion_expression_is_typed_ast",
        "conversion_input_type_exact",
        "conversion_result_type_exact",
        "mixed_ms_ns_operator_arguments"
        ,"typed_constant_source_text_is_not_parsed"
        ,"all_literals_have_explicit_type_and_unit"
        ,"signed_int64_bounds_source"
        ,"signed_int64_schema_bounds_equal_registry"
      ],
      "properties": {
        "policy_id_unique": {
          "const": true
        },
        "object_class_unique": {
          "const": true
        },
        "unknown_policy": {
          "const": "reject"
        },
        "formula_id_unique": {
          "const": true
        },
        "all_formula_references_resolve": {
          "const": true
        },
        "unused_formula": {
          "const": "reject"
        },
        "all_operand_references_resolve": {
          "const": true
        },
        "all_operator_references_resolve": {
          "const": true
        },
        "operator_type_mismatch": {
          "const": "reject"
        },
        "clock_domain_mismatch": {
          "const": "reject"
        },
        "overflow": {
          "const": "reject_without_state_change"
        },
        "negative_or_fractional_milliseconds": {
          "const": "reject"
        },
        "duration_le_max_lifetime": {
          "const": true
        },
        "renew_before_lt_duration": {
          "const": true
        },
        "db_clock_backward": {
          "const": "do-not-expire-early-and-require-next-successful-BEGIN-IMMEDIATE-clock-sample"
        },
        "monotonic_clock_rollback": {
          "const": "fatal-process-invariant"
        },
        "conversion_expression_is_typed_ast": {
          "const": true
        },
        "conversion_input_type_exact": {
          "const": "int64_ns"
        },
        "conversion_result_type_exact": {
          "const": "int64_ms"
        },
        "mixed_ms_ns_operator_arguments": {
          "const": "reject"
        },
        "typed_constant_source_text_is_not_parsed": {
          "const": true
        },
        "all_literals_have_explicit_type_and_unit": {
          "const": true
        },
        "signed_int64_bounds_source": {
          "const": "contract-registry-v1#/raw_bounds/integer_min|integer_max"
        },
        "signed_int64_schema_bounds_equal_registry": {
          "const": true
        }
      },
      "additionalProperties": false
    }
  },
  "x-aq-array-order": {
    "$schema": "https://agent-quota.local/contracts/schemas/contract-registry-v1.schema.json#/$defs/arrayOrderMetadata",
    "dialect": "aq-array-order-v1",
    "version": 1,
    "default": "sequence_exact",
    "overrides": [
      {
        "schema_pointer": "/properties/clock_domains",
        "policy": "utf8_key",
        "key_json_pointers": [
          "/clock_id"
        ]
      },
      {
        "schema_pointer": "/properties/formula_definitions",
        "policy": "utf8_key",
        "key_json_pointers": [
          "/formula_id"
        ]
      },
      {
        "schema_pointer": "/properties/operand_definitions",
        "policy": "utf8_key",
        "key_json_pointers": [
          "/operand_id"
        ]
      },
      {
        "schema_pointer": "/properties/operators",
        "policy": "utf8_key",
        "key_json_pointers": [
          "/op"
        ]
      },
      {
        "schema_pointer": "/properties/policies",
        "policy": "utf8_key",
        "key_json_pointers": [
          "/policy_id"
        ]
      }
    ],
    "coverage_rule": "every-schema-object-with-type-array-resolves-to-exactly-one-policy; duplicate-or-dangling-override-reject"
  }
}
