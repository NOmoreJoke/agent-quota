  "closure_rules": {
    "policy_id_unique": true,
    "object_class_unique": true,
    "unknown_policy": "reject",
    "formula_id_unique": true,
    "all_formula_references_resolve": true,
    "unused_formula": "reject",
    "all_operand_references_resolve": true,
    "all_operator_references_resolve": true,
    "operator_type_mismatch": "reject",
