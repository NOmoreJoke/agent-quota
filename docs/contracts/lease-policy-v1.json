      "output_type": "boolean",
      "min_args": 2,
      "max_args": 2,
      "overflow": "not-applicable"
    },
    {
      "op": "less_than",
      "input_type": "same_scalar_pair",
      "output_type": "boolean",
      "min_args": 2,
      "max_args": 2,
      "overflow": "not-applicable"
    },
    {
      "op": "min",
      "input_type": "int64_ms[]",
      "output_type": "int64_ms",
      "min_args": 2,
      "max_args": 4,
      "overflow": "not-applicable"
    },
    {
      "op": "min_int64_ns",
      "input_type": "int64_ns[]",
      "output_type": "int64_ns",
      "min_args": 2,
      "max_args": 4,
      "overflow": "not-applicable"
    },
    {
      "op": "subtract_clamped_zero_int64_ns",
