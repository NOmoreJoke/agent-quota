      "path": "docs/audits/gui-product-decision-resolution.md",
      "category": "non-history-normative-decision-input",
      "record_kind": "normative-product-decision-non-history",
      "decision_status": "confirmed-current-pending-independent-r20",
      "history_membership": "forbidden-not-audit-not-resolution",
      "first_line": "# GUI 产品决策处置记录（非审计轮次）",
      "projection_marker": "AQ-NORMATIVE-PRODUCT-DECISION-V1",
      "raw_sha256": "fc3bdd90d8e5d66bd2b969b08e6f3c8d80f95e6a24702eb1a4c7fb5850cd559a"
    }
  ],
  "array_order_dialect": {
    "dialect": "aq-array-order-v1",
    "version": 1,
    "meta_schema_uri": "https://agent-quota.local/contracts/schemas/contract-registry-v1.schema.json#/$defs/arrayOrderMetadata",
    "default_policy": "sequence_exact",
    "override_policy": "utf8_key"
  },
  "canonicalizer": {
    "implementation_path": "docs/contracts/canonicalize-registry-v1.py",
    "implementation_version": "aq-canonicalizer-v1",
    "validator_path": "docs/contracts/validate-contracts-v1.py",
    "validator_version": "aq-contract-validator-v1",
    "execution_mode": "read-only-verifier",
    "trust_status": "audit-evidence-only-not-a-release-authority",
    "production_authority": "externally-pinned-signed-release-or-vcs-commit-plus-tool-raw-sha256-and-prior-root-authorization",
    "self_pin_update": "forbidden",
    "input_paths": [
      "docs/contracts/core-safety-contract-v1.json",
      "docs/contracts/fixtures/core-safety-v1.json",
      "docs/contracts/fixtures/retention-lint-malicious-v1.json",
      "docs/contracts/lease-policy-v1.json",
      "docs/contracts/local-key-purpose-registry-v1.json",
      "docs/contracts/operation-contract-v1.json",
      "docs/contracts/retention-lint-v1.json",
      "docs/contracts/schemas/contract-registry-v1.schema.json",
      "docs/contracts/schemas/core-safety-contract-v1.schema.json",
      "docs/contracts/schemas/lease-policy-v1.schema.json",
      "docs/contracts/schemas/local-key-purpose-registry-v1.schema.json",
      "docs/contracts/schemas/operation-contract-v1.schema.json",
      "docs/contracts/schemas/retention-lint-v1.schema.json"
    ],
    "registry_anchor_recipe": "SHA256(ASCII('agent-quota:contract-registry:v1\\x00')||aq-jcs-nfc-v1(registry-with-current-pins))"
  },
  "digest_recipes": {
    "artifact_canonical": "SHA256(ASCII('agent-quota:contract-artifact:v1\\x00')||aq-jcs-nfc-v1(document))",
    "schema_canonical": "SHA256(ASCII('agent-quota:contract-schema:v1\\x00')||aq-jcs-nfc-v1(schema_document))",
    "raw": "SHA256(raw_bytes)"
  },
  "raw_bounds": {
    "registry_raw_bytes_max": 65536,
    "artifact_raw_bytes_max": 524288,
    "schema_raw_bytes_max": 262144,
    "json_depth_max": 64,
    "json_nodes_max": 100000,
    "string_utf8_bytes_max": 16384,
    "array_items_max": 4096,
    "integer_min": -9223372036854775808,
    "integer_max": 9223372036854775807,
    "floats": "reject",
    "non_finite_numbers": "reject",
    "duplicate_keys": "reject_before_schema"
  },
  "path_resolution": {
    "fixed_root": "repository-root-opened-once-as-directory-handle",
    "segment_validation": "ASCII-lowercase-contract-path-components-with-no-dot-dot-empty-or-separator-encoding",
    "decode_or_normalize": "forbidden",
    "open_algorithm": "openat-each-component-relative-to-fixed-root",
    "symlink_policy": "O_NOFOLLOW-every-component",
    "final_identity_check": "resolved-relative-path-bytes-must-equal-registered-path-bytes"
  },
  "validation_order": [
    "registry_raw_bounds",
    "utf8_decode_and_nfc",
    "strict_json_parse",
    "registry_schema_hash",
    "registry_schema_validate",
    "artifact_raw_bounds",
    "artifact_raw_hash",
    "schema_raw_bounds",
    "schema_raw_and_canonical_hash",
    "schema_meta_validate",
    "artifact_schema_validate",
    "semantic_closure_validate"
  ],
  "schema_binding": {
    "schema_path": "docs/contracts/schemas/contract-registry-v1.schema.json",
    "schema_uri": "https://agent-quota.local/contracts/schemas/contract-registry-v1.schema.json",
