  "semantic_validators": [
    {
      "validator_id": "array-order-dialect-v1",
      "applies_to": "all",
      "rule": "Every schema uses exactly aq-array-order-v1 and its metadata validates against the registered arrayOrderMetadata fragment; no legacy field spelling is accepted.",
      "verdict": "reject"
    },
    {
      "validator_id": "core-safety-closure-v1",
      "applies_to": "core-safety-contract-v1",
      "rule": "Codex bundle roots, identity bootstrap, budget groups, migration membership, installation registry and repository path fixtures close exactly and all expected verdicts match.",
      "verdict": "reject"
    },
    {
      "validator_id": "core-safety-fixture-runner-v1",
      "applies_to": "core-safety-contract-v1",
      "rule": "Run every strict discriminated fixture from domain plus input only; fixture_id is diagnostic and changing it cannot change actual computation or verdict.",
      "verdict": "reject"
    },
    {
      "validator_id": "heading-number-and-anchor-v1",
      "applies_to": "all",
      "rule": "Ignore fenced code, then require numbered headings to match Markdown level, have an existing numbered parent, and be unique/strictly monotonic among siblings; every local Markdown anchor must resolve to an exact generated heading slug.",
      "verdict": "reject"
    },
    {
      "validator_id": "key-entry-semantics-v1",
      "applies_to": "local-key-purpose-registry-v1",
      "rule": "Recompute every key_id from exact bytes, enforce public_salt role, one active generation per purpose, transition policy, sorted unique tuples and the complete payload-envelope golden vector.",
      "verdict": "reject"
    },
    {
      "validator_id": "lease-formula-closure-v1",
      "applies_to": "lease-policy-v1",
      "rule": "Formula IDs, operands and operators form exact used reference sets; typed AST inference succeeds; clock conversion and checked arithmetic never overflow.",
      "verdict": "reject"
    },
    {
      "validator_id": "normative-decision-input-v1",
      "applies_to": "all",
      "rule": "The one non-history normative decision input is no-follow read, raw pinned, structurally marked as neither audit nor resolution, projected from current product/Codex/OpenRouter machine contracts, and linked exactly by all four live documents.",
      "verdict": "reject"
    },
    {
      "validator_id": "operation-reference-closure-v1",
      "applies_to": "operation-contract-v1",
      "rule": "Predicate, safe enum, path, stage, error and provider I/O definition sets are bijective where declared; no dangling, duplicate or unused member exists.",
      "verdict": "reject"
    },
    {
      "validator_id": "probe-result-closure-v1",
      "applies_to": "core-safety-contract-v1",
      "rule": "ProbeResult is a closed discriminated carrier; only official_cli_success carries one short-lived OfficialProtocolIdentityEvidence and every other branch forbids evidence and derived identity fields before identity_derive.",
      "verdict": "reject"
    },
    {
      "validator_id": "purpose-consumer-closure-v1",
      "applies_to": "local-key-purpose-registry-v1",
      "rule": "Every purpose has consumer coverage; every consumer has one purpose and lookup policy; persistent surfaces close consumer references and bounded generation products.",
      "verdict": "reject"
    },
    {
      "validator_id": "repo-path-v1",
      "applies_to": "all",
      "rule": "Every registered RepoPath field matches canonical bytes, rejects dot, dot-dot, empty, repeated slash, percent, Unicode, case and backslash aliases, and resolves from one opened root using openat O_NOFOLLOW per segment.",
      "verdict": "reject"
    },
    {
      "validator_id": "retention-detector-closure-v1",
      "applies_to": "retention-lint-v1",
      "rule": "Pandoc version, reader extensions and API version match; locators hit once; record v1 binds surface, operation and owner in one Code span; records are removed before residual prose signals are independently rejected; every fixture is evaluated independent of fixture_id and equals expected.",
      "verdict": "reject"
    },
    {
      "validator_id": "schema-array-order-coverage-v1",
      "applies_to": "all",
      "rule": "Enumerate every schema object whose type is array; the root x-aq-array-order default plus exact JSON-pointer overrides resolve exactly one policy per array; duplicate or dangling overrides reject; utf8_key tuple arrays and sequence_exact arrays validate byte-for-byte.",
      "verdict": "reject"
    },
    {
      "validator_id": "strict-integer-type-v1",
      "applies_to": "all",
      "rule": "JSON boolean is never accepted as integer, floats and non-finite values reject, and all integer range checks occur before arithmetic.",
      "verdict": "reject"
    },
    {
      "validator_id": "validation-mutation-contract-v1",
      "applies_to": "core-safety-contract-v1",
      "rule": "Mutation case sequence, ID, expected verdict, canonical RepoPath, structured locator, before/after, expected failure class, executor ID/source digest, mutation identity digest, case count and canonical result field closure are fixed outside the runner; validator and release gate independently parse the runner AST and exact-match emitted input/recipe/mutated/failure evidence.",
      "verdict": "reject"
    }
  ],
  "closure_rules": {
    "artifact_id_unique": true,
    "artifact_path_unique": true,
    "artifact_schema_uri_matches_document_schema": true,
    "schema_id_matches_bound_uri": true,
    "schema_meta_schema_exact": true,
    "schema_hash_mismatch": "reject",
    "artifact_hash_mismatch": "reject",
    "unknown_artifact": "reject",
    "unknown_schema": "reject",
    "array_order": "schema-x-aq-array-order-exact-policy",
    "array_uniqueness": "policy-key-tuple-or-canonical-item-bytes",
    "semantic_validator_id_unique": true,
    "unused_semantic_validator": "reject",
    "path_outside_fixed_root": "reject",
    "path_redecode_or_normalize": "reject",
    "symlink_or_case_alias": "reject"
  }
}
